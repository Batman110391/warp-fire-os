<?xml version="1.0" encoding="utf-8"?>
<!-- Remotes have no hover: focus must be unmistakable. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tv_accent" />
            <stroke android:width="4dp" android:color="@color/tv_text" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tv_accent" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/tv_surface" />
            <stroke android:width="2dp" android:color="@color/tv_text_dim" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
