<?xml version="1.0" encoding="utf-8"?>
<!-- Drawn by the ListView behind the focused row. Rows themselves never take focus, so the
     highlight cannot live on the row background. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tv_accent" />
            <stroke android:width="4dp" android:color="@color/tv_text" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tv_accent" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
