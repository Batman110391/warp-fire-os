<?xml version="1.0" encoding="utf-8"?>
<!-- ScrollView so the button column always fits, whatever the TV's overscan and density. The
     D-pad scrolls it automatically as focus moves between buttons. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tv_background"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:longClickable="true"
            android:text="@string/app_name"
            android:textColor="@color/tv_text"
            android:textSize="36sp" />

        <TextView
            android:id="@+id/status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/status_disconnected"
            android:textColor="@color/tv_text_dim"
            android:textSize="26sp" />

        <TextView
            android:id="@+id/detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/tv_text_dim"
            android:textSize="18sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/warp_button"
            android:layout_width="360dp"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/button_background"
            android:focusable="true"
            android:text="@string/warp_off"
            android:textColor="@color/tv_text"
            android:textSize="18sp" />

        <Button
            android:id="@+id/apps_button"
            android:layout_width="360dp"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_background"
            android:focusable="true"
            android:text="@string/apps_all"
            android:textColor="@color/tv_text"
            android:textSize="18sp" />

        <Button
            android:id="@+id/autoconnect_button"
            android:layout_width="360dp"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_background"
            android:focusable="true"
            android:text="@string/autoconnect_on"
            android:textColor="@color/tv_text"
            android:textSize="18sp" />

        <Button
            android:id="@+id/action_button"
            android:layout_width="360dp"
            android:layout_height="88dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/button_background"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:text="@string/action_connect"
            android:textColor="@color/tv_text"
            android:textSize="26sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/hint_reset"
            android:textColor="@color/tv_text_dim"
            android:textSize="13sp" />

    </LinearLayout>

</ScrollView>
