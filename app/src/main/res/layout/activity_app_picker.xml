<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tv_background"
    android:orientation="vertical"
    android:paddingStart="48dp"
    android:paddingEnd="48dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/picker_title"
        android:textColor="@color/tv_text"
        android:textSize="32sp" />

    <TextView
        android:id="@+id/app_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/tv_text_dim"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/app_list_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/picker_empty"
        android:textColor="@color/tv_text_dim"
        android:textSize="18sp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/app_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="4dp"
        android:drawSelectorOnTop="false"
        android:listSelector="@drawable/row_selector"
        android:scrollbars="none" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/picker_hint"
        android:textColor="@color/tv_text_dim"
        android:textSize="14sp" />

</LinearLayout>
